 UPDATE sales
SET amount = 
    CASE 
        WHEN UPPER(TRIM(product)) = 'LAPTOP' THEN 1200
        WHEN UPPER(TRIM(product)) = 'PHONE' THEN 800
        WHEN UPPER(TRIM(product)) = 'TABLET' THEN 400

        WHEN UPPER(TRIM(product)) = 'MOUSE' THEN UNIFORM(20, 100, RANDOM())
        WHEN UPPER(TRIM(product)) = 'MONITOR' THEN UNIFORM(150, 500, RANDOM())
        WHEN UPPER(TRIM(product)) = 'HEADPHONES' THEN UNIFORM(50, 300, RANDOM())
        WHEN UPPER(TRIM(product)) = 'KEYBOARD' THEN UNIFORM(30, 150, RANDOM())
    END
WHERE amount IS NULL;


